{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crossborder.local/capm/cross_skill_envelope.schema.json",
  "title": "CAPM cross-skill decision envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_id", "contract_version", "message_id", "correlation_id", "idempotency_key", "sender", "receiver", "object", "scope", "status", "source_evidence_level", "causal_evidence_level", "claim_ids", "evidence_ids", "calculation_ids", "allowed_uses", "forbidden_uses", "blocked_actions", "accepted_by_receiver", "lineage", "validity", "payload"],
  "properties": {
    "contract_id": {"type": "string", "minLength": 1},
    "contract_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "message_id": {"type": "string", "minLength": 1},
    "correlation_id": {"type": "string", "minLength": 1},
    "idempotency_key": {"type": "string", "minLength": 1},
    "causation_id": {"type": ["string", "null"]},
    "supersedes_message_id": {"type": ["string", "null"]},
    "sender": {"$ref": "#/$defs/party"},
    "receiver": {"$ref": "#/$defs/party"},
    "object": {"type": "object", "additionalProperties": false, "required": ["canonical_id", "object_type", "object_version"], "properties": {"canonical_id": {"type": "string", "minLength": 1}, "object_type": {"type": "string", "minLength": 1}, "object_version": {"type": "string", "minLength": 1}}},
    "scope": {"type": "object", "additionalProperties": false, "required": ["platform", "country", "currency", "timezone", "as_of_time"], "properties": {"platform": {"type": "string", "minLength": 1}, "country": {"type": "string", "pattern": "^[A-Z]{2}$"}, "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}, "timezone": {"type": "string", "minLength": 1}, "as_of_time": {"type": "string", "format": "date-time"}}},
    "status": {"enum": ["proposed", "validated", "blocked", "inconclusive", "superseded"]},
    "source_evidence_level": {"enum": ["S0", "S1", "S2", "S3", "S4"]},
    "causal_evidence_level": {"enum": ["C0", "C1", "C2", "C3"]},
    "claim_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "evidence_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "calculation_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "allowed_uses": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "forbidden_uses": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "blocked_actions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "accepted_by_receiver": {"type": "object", "additionalProperties": false, "required": ["status", "reason", "checked_at"], "properties": {"status": {"enum": ["pending", "accepted", "rejected"]}, "reason": {"type": ["string", "null"]}, "checked_at": {"type": ["string", "null"], "format": "date-time"}}},
    "lineage": {"type": "object", "additionalProperties": false, "required": ["input_hash", "output_hash", "schema_hash"], "properties": {"input_hash": {"$ref": "#/$defs/hash"}, "output_hash": {"$ref": "#/$defs/hash"}, "schema_hash": {"$ref": "#/$defs/hash"}}},
    "validity": {"type": "object", "additionalProperties": false, "required": ["valid_from", "expires_at", "recompute_trigger"], "properties": {"valid_from": {"type": "string", "format": "date-time"}, "expires_at": {"type": "string", "format": "date-time"}, "recompute_trigger": {"type": "array", "minItems": 1, "items": {"type": "string"}}}},
    "payload": {"type": "object"}
  },
  "$defs": {
    "party": {"type": "object", "additionalProperties": false, "required": ["skill", "runtime_version"], "properties": {"skill": {"type": "string", "minLength": 1}, "runtime_version": {"type": "string", "minLength": 1}}},
    "hash": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"}
  }
}
